# ===========================================

# Remove logging in release
-assumenosideeffects class android.util.Log {
    public static int v(...);
    public static int d(...);
    public static int i(...);
}

# Optimize string operations
-optimizationpasses 5
-optimizations !code/simplification/arithmetic,!field/*,!class/merging/*

