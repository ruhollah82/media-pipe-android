import { useRef, useEffect, useCallback } from 'react';
import { usePoseStore } from '../store/usePoseStore';
import { POSE_CONNECTIONS } from '../lib/pose-connections';
import { BODY_REGIONS, LABELED_LANDMARKS } from '../lib/body-regions';
import type { NormalizedLandmark } from '../types';

const LANDMARK_COLOR = '#00FF00';
const SKELETON_COLOR = '#00FFFF';
const LABEL_COLOR = '#FFFFFF';
const LABEL_BG = 'rgba(0, 0, 0, 0.6)';
const POINT_RADIUS = 4;
const LINE_WIDTH = 2;
const VISIBILITY_THRESHOLD = 0.5;

export function PoseCanvas() {
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const ctxRef = useRef<CanvasRenderingContext2D | null>(null);
  const lastLandmarksRef = useRef<NormalizedLandmark[] | null>(null);
  const rafIdRef = useRef<number>(0);
  const isRenderingRef = useRef<boolean>(false);

  const landmarks = usePoseStore((s) => s.landmarks);

  // Cache canvas context with optimal settings
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    
    ctxRef.current = canvas.getContext('2d', {
      willReadFrequently: false,
      alpha: true,
      desynchronized: true, // Reduce latency on supported devices
    });
  }, []);

  // Optimized render function
  const render = useCallback(() => {
    const ctx = ctxRef.current;
    const canvas = canvasRef.current;
    const landmarks = lastLandmarksRef.current;
    
    if (!ctx || !canvas) return;

    const { width, height } = canvas;
    if (width === 0 || height === 0) return;

    // Clear canvas
    ctx.clearRect(0, 0, width, height);

    if (!landmarks) return;

    // Batch style changes
    ctx.lineWidth = LINE_WIDTH;
    ctx.font = '12px monospace';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';

    // Draw skeleton first (behind landmarks)
    ctx.strokeStyle = SKELETON_COLOR;
    ctx.beginPath();
    for (const [i, j] of POSE_CONNECTIONS) {
      const a = landmarks[i];
      const b = landmarks[j];
      if (!a || !b) continue;
      if (a.visibility < VISIBILITY_THRESHOLD || b.visibility < VISIBILITY_THRESHOLD) continue;

      ctx.moveTo(a.x * width, a.y * height);
      ctx.lineTo(b.x * width, b.y * height);
    }
    ctx.stroke();

    // Draw landmarks
    ctx.fillStyle = LANDMARK_COLOR;
    ctx.beginPath();
    for (const lm of landmarks) {
      if (lm.visibility < VISIBILITY_THRESHOLD) continue;
      const x = lm.x * width;
      const y = lm.y * height;
      ctx.moveTo(x + POINT_RADIUS, y);
      ctx.arc(x, y, POINT_RADIUS, 0, 2 * Math.PI);
    }
    ctx.fill();

    // Draw labels
    for (const idx of LABELED_LANDMARKS) {
      const lm = landmarks[idx];
      if (!lm || lm.visibility < VISIBILITY_THRESHOLD) continue;

      const label = BODY_REGIONS[idx];
      if (!label) continue;

      const x = lm.x * width;
      const y = lm.y * height;
      const textWidth = ctx.measureText(label).width;

      // Draw background
      ctx.fillStyle = LABEL_BG;
      ctx.fillRect(x + 6, y - 8, textWidth + 8, 16);

      // Draw text
      ctx.fillStyle = LABEL_COLOR;
      ctx.fillText(label, x + 10, y);
    }
  }, []);

  // Render loop with proper cleanup
  useEffect(() => {
    lastLandmarksRef.current = landmarks;

    if (!isRenderingRef.current) {
      isRenderingRef.current = true;
      
      const loop = () => {
        render();
        rafIdRef.current = requestAnimationFrame(loop);
      };
      
      rafIdRef.current = requestAnimationFrame(loop);
    }

    return () => {
      if (rafIdRef.current) {
        cancelAnimationFrame(rafIdRef.current);
        rafIdRef.current = 0;
        isRenderingRef.current = false;
      }
    };
  }, [landmarks, render]);

  // Sync canvas dimensions from parent video element
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const parent = canvas.parentElement;
    if (!parent) return;

    const video = parent.querySelector('video');
    if (!video) return;

    const syncDimensions = () => {
      if (video.videoWidth > 0 && video.videoHeight > 0) {
        if (canvas.width !== video.videoWidth || canvas.height !== video.videoHeight) {
          canvas.width = video.videoWidth;
          canvas.height = video.videoHeight;
        }
      }
    };

    video.addEventListener('loadedmetadata', syncDimensions);
    // Also check periodically in case metadata loads late
    const interval = setInterval(syncDimensions, 500);

    return () => {
      video.removeEventListener('loadedmetadata', syncDimensions);
      clearInterval(interval);
    };
  }, []);

  return (
    <canvas
      ref={canvasRef}
      className="absolute inset-0 w-full h-full pointer-events-none"
      style={{ zIndex: 10 }}
    />
  );
}
</file>

<file path="src/hooks/useCamera.ts">
import { useRef, useState, useEffect, useCallback } from 'react';

interface UseCameraReturn {
  videoRef: React.RefObject<HTMLVideoElement | null>;
  isActive: boolean;
  error: string | null;
  start: () => Promise<void>;
  stop: () => void;
}

export function useCamera(): UseCameraReturn {
  const videoRef = useRef<HTMLVideoElement | null>(null);
  const streamRef = useRef<MediaStream | null>(null);
  const [isActive, setIsActive] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const start = useCallback(async () => {
    try {
      setError(null);

      const stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: 'user',
          width: { ideal: 1280 },
          height: { ideal: 720 },
        },
        audio: false,
      });

      streamRef.current = stream;

      if (videoRef.current) {
        videoRef.current.srcObject = stream;
        await videoRef.current.play();
        setIsActive(true);
      }
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Failed to access camera';
      setError(message);
      setIsActive(false);
    }
  }, []);

  const stop = useCallback(() => {
    if (streamRef.current) {
      streamRef.current.getTracks().forEach((track) => track.stop());
      streamRef.current = null;
    }
    if (videoRef.current) {
      videoRef.current.srcObject = null;
    }
    setIsActive(false);
  }, []);

  // Handle visibility changes (pause/resume camera when app backgrounds)
  useEffect(() => {
    const handleVisibilityChange = () => {
      if (!streamRef.current) return;

      if (document.hidden) {
        // Pause camera tracks
        streamRef.current.getTracks().forEach((track) => {
          track.enabled = false;
        });
      } else {
        // Resume camera tracks
        streamRef.current.getTracks().forEach((track) => {
          track.enabled = true;
        });
      }
    };

    document.addEventListener('visibilitychange', handleVisibilityChange);
    return () => {
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    };
  }, []);

  // Cleanup on unmount
  useEffect(() => {
    return () => {
      stop();
    };
  }, [stop]);

  return { videoRef, isActive, error, start, stop };
}
