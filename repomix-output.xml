import { useEffect, useRef, useState } from 'react';
import { useCamera } from '../hooks/useCamera';
import { usePoseLandmarker } from '../hooks/usePoseLandmarker';
import { usePoseStore } from '../store/usePoseStore';
import { PoseCanvas } from './PoseCanvas';

export function CameraView() {
  const { videoRef, isActive, error: cameraError, start } = useCamera();
  const { isReady, error: poseError, startDetection, stopDetection } = usePoseLandmarker();
  const status = usePoseStore((s) => s.status);
  const landmarks = usePoseStore((s) => s.landmarks);
  const detectionStartedRef = useRef(false);
  const [fps, setFps] = useState(0);
  const fpsRef = useRef({ frames: 0, lastTime: performance.now() });

  // Start camera on mount
  useEffect(() => {
    start();
  }, [start]);

  // Start detection when both camera and PoseLandmarker are ready
  useEffect(() => {
    if (isReady && isActive && videoRef.current && !detectionStartedRef.current) {
      detectionStartedRef.current = true;
      startDetection(videoRef.current);
    }
  }, [isReady, isActive, videoRef, startDetection]);

  // Stop detection when camera stops
  useEffect(() => {
    if (!isActive) {
      detectionStartedRef.current = false;
      stopDetection();
    }
  }, [isActive, stopDetection]);

  // FPS counter
  useEffect(() => {
    if (!isActive) return;

    const interval = setInterval(() => {
      const now = performance.now();
      const elapsed = now - fpsRef.current.lastTime;
      if (elapsed >= 1000) {
        setFps(Math.round((fpsRef.current.frames * 1000) / elapsed));
        fpsRef.current.frames = 0;
        fpsRef.current.lastTime = now;
      }
    }, 100);

    const countFrame = () => {
      fpsRef.current.frames++;
      requestAnimationFrame(countFrame);
    };
    const rafId = requestAnimationFrame(countFrame);

    return () => {
      clearInterval(interval);
      cancelAnimationFrame(rafId);
    };
  }, [isActive]);

  const error = cameraError || poseError;

  return (
    <div className="relative w-full h-screen bg-black overflow-hidden select-none">
      {/* Camera video feed */}
      <video
        ref={videoRef}
        autoPlay
        playsInline
        muted
        className="absolute inset-0 w-full h-full object-cover"
        style={{ transform: 'scaleX(-1)' }} // Mirror for front camera
      />

      {/* Pose overlay canvas */}
      <PoseCanvas />

      {/* Status indicator */}
      <div className="absolute top-4 left-4 z-20">
        <div
          className={`px-3 py-1.5 rounded-full text-xs font-semibold backdrop-blur-sm ${
            status === 'ready' && isActive
              ? 'bg-green-500/80 text-white'
              : status === 'loading'
                ? 'bg-yellow-500/80 text-white'
                : status === 'error'
                  ? 'bg-red-500/80 text-white'
                  : 'bg-gray-500/80 text-white'
          }`}
        >
          {status === 'ready' && isActive
            ? '● Detecting'
            : status === 'loading'
              ? '◌ Loading...'
              : status === 'error'
                ? '✕ Error'
                : '◌ Init...'}
        </div>
      </div>

      {/* FPS and landmarks count */}
      {isActive && status === 'ready' && (
        <div className="absolute top-4 right-4 z-20">
          <div className="px-3 py-1.5 rounded-full text-xs font-mono bg-black/50 text-white backdrop-blur-sm">
            {fps} FPS · {landmarks ? landmarks.length : 0} pts
          </div>
        </div>
      )}

      {/* Error display */}
      {error && (
        <div className="absolute bottom-20 left-4 right-4 z-20 bg-red-500/90 text-white p-4 rounded-xl text-sm backdrop-blur-sm">
          <p className="font-semibold mb-1">Error</p>
          <p className="text-red-100">{error}</p>
        </div>
      )}

      {/* Camera not active hint */}
      {!isActive && !cameraError && (
        <div className="absolute inset-0 flex items-center justify-center z-20 bg-black/70">
          <div className="text-white text-center px-8">
            <div className="text-6xl mb-4">📷</div>
            <p className="text-xl font-semibold mb-2">Camera Access Required</p>
            <p className="text-sm text-gray-300 mb-4">
              Please allow camera permission when prompted
            </p>
            <button
              onClick={start}
              className="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg text-sm font-medium transition-colors"
            >
              Try Again
            </button>
          </div>
        </div>
      )}

      {/* Loading model overlay */}
      {isActive && status === 'loading' && (
        <div className="absolute inset-0 flex items-center justify-center z-20 bg-black/50">
          <div className="text-white text-center">
            <div className="animate-spin w-12 h-12 border-4 border-white/30 border-t-white rounded-full mx-auto mb-4" />
            <p className="text-lg font-medium">Loading Pose Detection Model...</p>
            <p className="text-sm text-gray-300 mt-1">This may take a moment on first load</p>
          </div>
        </div>
      )}

      {/* Instructions overlay (shown briefly) */}
      <InstructionsOverlay />
    </div>
  );
}

function InstructionsOverlay() {
  const [show, setShow] = useState(true);

  useEffect(() => {
    const timer = setTimeout(() => setShow(false), 5000);
    return () => clearTimeout(timer);
  }, []);

  if (!show) return null;

  return (
    <div className="absolute bottom-4 left-4 right-4 z-20 bg-black/70 text-white p-4 rounded-xl text-sm backdrop-blur-sm animate-fade-in">
      <p className="font-medium mb-1">How to use:</p>
      <ul className="text-gray-300 space-y-1">
        <li>• Stand in view of the camera</li>
        <li>• Body regions will be detected automatically</li>
        <li>• Works best with good lighting</li>
      </ul>
    </div>
  );
}
