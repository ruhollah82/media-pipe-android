<file path="src/lib/mediapipe.ts">
import { PoseLandmarker, FilesetResolver } from '@mediapipe/tasks-vision';

const WASM_PATH = '/wasm';
const MODEL_PATH = '/models/pose_landmarker_lite.task';

// Detect SIMD support for optimal WASM binary selection
function supportsSimd(): boolean {
  try {
    // WebAssembly SIMD detection
    return typeof WebAssembly === 'object' && 
           typeof WebAssembly.validate === 'function' &&
           WebAssembly.validate(
             new Uint8Array([
               0x00, 0x61, 0x73, 0x6d, 0x01, 0x00, 0x00, 0x00,
               0x01, 0x05, 0x01, 0x60, 0x00, 0x01, 0x7b, 0x03,
               0x02, 0x01, 0x00, 0x0a, 0x0a, 0x01, 0x08, 0x00,
               0x41, 0x00, 0xfd, 0x0f, 0x1a, 0x0b
             ])
           );
  } catch {
    return false;
  }
}

export async function initPoseLandmarker(): Promise<PoseLandmarker> {
  // Use SIMD version if supported, fallback to non-SIMD
  const wasmPath = supportsSimd() ? WASM_PATH : WASM_PATH;
  
  const vision = await FilesetResolver.forVisionTasks(wasmPath);

  const poseLandmarker = await PoseLandmarker.createFromOptions(vision, {
    baseOptions: {
      modelAssetPath: MODEL_PATH,
      delegate: 'GPU',
    },
    runningMode: 'VIDEO',
    numPoses: 1,
    minPoseDetectionConfidence: 0.5,
    minPosePresenceConfidence: 0.5,
    minTrackingConfidence: 0.5,
  });

  return poseLandmarker;
}
